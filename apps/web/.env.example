# Leave as localhost or omit — browser will use same-origin /api proxy (see next.config rewrites)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
# Optional proxy target when using /api rewrite (default http://127.0.0.1:8000)
# API_PROXY_TARGET=http://127.0.0.1:8000
# Set true to log auth token presence and request headers (dev also logs by default)
NEXT_PUBLIC_AUTH_DEBUG=true
# Optional: set after seeding org for marketplace deploy API (localStorage key: nexus_org_id)
